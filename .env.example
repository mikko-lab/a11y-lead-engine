# Redis — PAKOLLINEN: generoi vahva salasana, esim. openssl rand -hex 32
REDIS_PASSWORD=
REDIS_URL=redis://:REDIS_PASSWORD_HERE@127.0.0.1:6379

# Database
DATABASE_URL="file:./dev.db"

# Dashboard basic auth — PAKOLLINEN: vaihda oletukset ennen deployta
DASH_USER=admin
DASH_PASS=

# SMTP (esim. Gmail App Password, Brevo, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sinun@gmail.com
SMTP_PASS=app-password-tahan
SMTP_FROM="WP Saavutettavuus <sinun@gmail.com>"

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Sähköpostin etsintä
HUNTER_API_KEY=

# Brave Search
BRAVE_SEARCH_API_KEY=

# Deploy-palvelin (ei root-käyttäjää!)
DEPLOY_SERVER=a11y@your-server-ip

# Lähettäjän nimi raportissa
SENDER_NAME=WP Saavutettavuus
SENDER_URL=https://wpsaavutettavuus.fi
